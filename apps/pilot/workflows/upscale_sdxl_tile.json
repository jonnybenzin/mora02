{
  "1": {
    "inputs": {
      "image": "input_image.png"
    },
    "class_type": "LoadImage",
    "_meta": { "title": "Load Source Image" }
  },
  "2": {
    "inputs": {
      "ckpt_name": "Juggernaut-XL_v9_RunDiffusionPhoto_v2.safetensors"
    },
    "class_type": "CheckpointLoaderSimple",
    "_meta": { "title": "Load Juggernaut XL" }
  },
  "3": {
    "inputs": {
      "model_name": "4x-UltraSharp.pth"
    },
    "class_type": "UpscaleModelLoader",
    "_meta": { "title": "Load 4x-UltraSharp" }
  },
  "4": {
    "inputs": {
      "text": "highly detailed, sharp focus, photographic, 8k, no blur, no artifacts",
      "clip": ["2", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Positive Prompt" }
  },
  "5": {
    "inputs": {
      "text": "blurry, artifacts, low quality, jpeg compression, banding, oversharpened",
      "clip": ["2", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative Prompt" }
  },
  "6": {
    "inputs": {
      "image": ["1", 0],
      "model": ["2", 0],
      "positive": ["4", 0],
      "negative": ["5", 0],
      "vae": ["2", 2],
      "upscale_model": ["3", 0],
      "upscale_by": 2.0,
      "seed": 0,
      "steps": 20,
      "cfg": 6.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 0.2,
      "mode_type": "Linear",
      "tile_width": 1024,
      "tile_height": 1024,
      "mask_blur": 8,
      "tile_padding": 32,
      "seam_fix_mode": "None",
      "seam_fix_denoise": 0.0,
      "seam_fix_mask_blur": 0,
      "seam_fix_width": 64,
      "seam_fix_padding": 16,
      "force_uniform_tiles": true,
      "tiled_decode": false
    },
    "class_type": "UltimateSDUpscale",
    "_meta": { "title": "Ultimate SD Upscale (SDXL-Tile)" }
  },
  "7": {
    "inputs": {
      "filename_prefix": "upscale",
      "images": ["6", 0]
    },
    "class_type": "SaveImage",
    "_meta": { "title": "Save Upscaled" }
  }
}
