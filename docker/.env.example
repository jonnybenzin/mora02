# =============================================================
# Mora02 — Zentrale Konfiguration
# =============================================================
# Bei Migration/Neuinstallation:
# 1. Diese Datei kopieren: cp .env.example .env
# 2. Alle Werte ausfüllen
# 3. docker compose up -d
# 4. inject-html-keys.sh ausführen
# 5. Manuell in UIs konfigurieren (siehe unten)
# =============================================================

# --- Bestehende Keys (LibreChat Legacy, Open-WebUI) ---
JWT_SECRET=
JWT_REFRESH_SECRET=
NODE_ENV=development
BACKEND_URL=http://localhost:3080
MONGO_URI=

# --- Baserow ---
BASEROW_TOKEN=
POSTGRES_BASEROW_PASSWORD=

# --- Dify ---
POSTGRES_DIFY_PASSWORD=
REDIS_PASSWORD=
DIFY_SECRET_KEY=
DIFY_INNER_API_KEY=

# --- Penpot ---
POSTGRES_TOOLS_PASSWORD=
PENPOT_DATABASE_PASSWORD=
PENPOT_SECRET_KEY=

# --- SearXNG ---
SEARXNG_SECRET_KEY=

# --- Claude (für Strategist Bot, Vision) ---
CLAUDE_API_KEY=

# --- Stock Photo APIs ---
PEXELS_API_KEY=
PIXABAY_API_KEY=

# --- LinkedIn OAuth ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=

# --- Dify App Tokens ---
# Diese werden von Dify generiert. Nach Dify-Setup auslesen:
# docker exec postgres-dify-new psql -U dify -d dify \
#   -c "SELECT a.name, at.token FROM api_tokens at JOIN apps a ON at.app_id=a.id;"
DIFY_APP_KEY_DAILY=
DIFY_APP_KEY_ASSISTANT=
DIFY_APP_KEY_SOCIALMEDIA=

# =============================================================
# MANUELL IN UIs KONFIGURIEREN (nicht über .env möglich):
# =============================================================
# Dify (http://mora02.local:8190):
#   → Settings → Model Provider → Anthropic: Claude API Key eingeben
#   → Settings → Model Provider → Mistral: Mistral API Key eingeben
#
# Activepieces (http://mora02.local:8089):
#   → Connections → Baserow: Token eingeben
#   → Connections → Gmail: OAuth Flow durchlaufen
# =============================================================
